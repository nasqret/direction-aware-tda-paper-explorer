@article{Potente2017,
   abstract = {Blood and lymphatic vessels have essential roles in physiology and disease. The endothelial cells that line these vessels specialize to fulfil the needs of the tissue that they pervade. Recent studies in animal models have provided insights into the mechanisms underlying vessel type- and organ-specific specialization, which is crucial for the understanding of several diseases.},
   author = {Michael Potente and Taija Mäkinen},
   doi = {10.1038/nrm.2017.36},
   issn = {14710080},
   issue = {8},
   journal = {Nature Reviews Molecular Cell Biology},
   pages = {477-494},
   publisher = {Nature Publishing Group},
   title = {Vascular heterogeneity and specialization in development and disease},
   volume = {18},
   url = {http://dx.doi.org/10.1038/nrm.2017.36},
   year = {2017}
}
@article{Unterleuthner2017,
   abstract = {© 2017, © 2017 Society for Laboratory Automation and Screening. Angiogenesis is a promising target for anticancer therapies, but also for treating other diseases with pathologic vessel development. Targeting the vascular endothelial growth factor (VEGF) pathway did not proof as effective as expected due to emerging intrinsic resistance mechanisms, as well as stromal contributions leading to drug insensitivity. Therefore, alternative strategies affecting the interaction of endothelial cells (ECs) with other stromal cells seem to be more promising. Human preclinical in vitro angiogenesis models successfully recapitulating these interactions are rare, and two-dimensional (2D) cell cultures cannot mimic tissue architecture in vivo. Consequently, models combining three-dimensionality with heterotypic cell interaction seem to be better suited. Here, we report on an improved human fibroblast–EC coculture assay mimicking sprouting angiogenesis from EC-covered microbeads resembling existing endothelial structures. Culture conditions were optimized to assess pro- and antiangiogenic compounds. Important characteristics of angiogenesis, that is, the number of sprouts and branch points, sprout length protrusion, and overall vessel structure areas, were quantified. Notably, the endothelial sprouts display lumen formation and basal membrane establishment. In this model, angiogenesis can be inhibited by genetic interference of pro-angiogenic factors expressed in the fibroblasts. Moreover, bona fide antiangiogenic drugs decreased, whereas pro-angiogenic factors increased vessel formation in 24-well and 96-well settings, demonstrating the applicability for screening approaches.},
   author = {Daniela Unterleuthner and Nina Kramer and Karoline Pudelko and Alexandra Burian and Markus Hengstschläger and Helmut Dolznig},
   doi = {10.1177/2472555216686529},
   issn = {24725560},
   issue = {5},
   journal = {SLAS Discovery},
   keywords = {3D coculture,angiogenesis,heterotypic cell–cell interactions,preclinical angiogenesis model,screening},
   pages = {602-613},
   title = {An Optimized 3D Coculture Assay for Preclinical Testing of Pro- and Antiangiogenic Drugs},
   volume = {22},
   year = {2017}
}
@article{Stoter2017,
   abstract = {We present a diffuse interface method for coupling free and porous-medium-type flows modeled by the Navier–Stokes and Darcy equations. Its essential component is a diffuse geometry model generated from the phase-field solution of a separate initial boundary value problem that is based on the Allen–Cahn equation. Phase-field approximations of the interface and its gradient are then employed to transfer all interface terms in the coupled variational flow formulation into volumetric terms. This eliminates the need for an explicit interface parametrization between the two flow regimes. We illustrate accuracy and convergence for a series of benchmark examples, using standard low-order stabilized finite element discretizations. Our diffuse interface method is particularly attractive for coupled flow analysis on imaging data with complex implicit interfaces, where procedures for deriving explicit surface parametrizations constitute a significant bottleneck. We demonstrate the potential of our method to establish seamless imaging-through-analysis workflows by computing a perfusion profile for a full-scale 3D human liver based on MRI scans.},
   author = {Stein K.F. Stoter and Peter Müller and Luca Cicalese and Massimiliano Tuveri and Dominik Schillinger and Thomas J.R. Hughes},
   doi = {10.1016/j.cma.2017.04.002},
   issn = {00457825},
   issue = {April},
   journal = {Computer Methods in Applied Mechanics and Engineering},
   keywords = {Allen–Cahn equation,Diffuse interface method,Imaging data,Liver,Navier–Stokes/Darcy coupling,Phase-field approximation},
   pages = {70-102},
   title = {A diffuse interface method for the Navier–Stokes/Darcy equations: Perfusion profile for a patient-specific human liver based on MRI scans},
   volume = {321},
   year = {2017}
}
@article{Vasilopoulos2016,
   abstract = {Two-phase fluid flows arise in a wide variety of industrial and scientific applications. Inherent feature of the two-phase flows is the topological evolution of the interface between the two fluids, which leads to the formation of various flow patterns or regimes that depend strongly on the properties of both fluids, the properties of the interface and the flow rate. Actually, the detailed description of a moving interface remains challenging from physical and computational points of view due to the stiff impact of surface tension and the discontinuity that arises in the stress and pressure field across the interface. The Master thesis deals with the simulation of prototype two-phase flows via the phase-field model. Throughout the present work, the two fluids are supposed to be Newtonian, incompressible, immiscible and of matched densities. Thus, the Navier-Stokes equations along with the Continuity equation for constant total density, govern the flow of the two fluids, while the Cahn-Hilliard equation is used to describe the evolution of the interface as well as to produce an additional term in the Navier-Stokes equations (modified Navier- Stokes) representing the surface tension force acting only on the interfacial region. Two numerical algorithms were developed for accurate time integration of the governing equations; one is used for the simulation of moderate and high Reynolds number flows and the other one for the simulation of low Reynolds number flows. In both cases the Cahn-Hilliard equation is always treated implicitly, while in the first case the modified Navier-Stokes equations are explicitly integrated, and semi-implicitly in the second case. The overall attempt, from the theoretical physical background to the development and implementation of the numerical algorithm, is presented in the following Chapters. In the second Chapter, the physical background regarding one- and two-phase fluid flows is introduced. Subsequently, in the third Chapter, the basic ideas of the phase-field model, as well as the Cahn-Hilliard equation are discussed and adapted to the context of fluid mechanics. Moreover, the hydrodynamic coupling of the well-known Navier-Stokes equations to the Cahn-Hilliard equation (NSCH model), is presented. The fourth Chapter, concerns the development of the numerical algorithm capable of solving two-dimensional problems of one- and two-phase transient fluid flows of moderate and high Reynolds numbers, including the tracking of the interface between the two continuum media. In order to investigate low Reynolds number fluid flows, a further modification of the numerical scheme is presented in the fifth Chapter. Performance of all the features of the code is verified on an extensive set of problems presented in the fifth Chapter. In particular, we investigate phase separation processes, to ensure the validity of our Cahn-Hilliard solver. Subsequently, we study the efficiency of the NSCH model in tracking an interface when large deformations are applied on it due to an imposed flow of a single vortex in a box. Finally, validation of our code has been achieved through studies into the fluid mechanics of several liquid-liquid systems, in terms of qualitative and quantitative results compared to other numerical experiments found in the literature. More precisely, a numerical study of interfacial instabilities due to viscosity stratification, when a planar interface is disturbed sinusoidally in a Couette flow, is presented, as well as an investigation of the effects of inertia on the deformation of liquid drops in simple shear flow.},
   author = {Yannis Vasilopoulos},
   issue = {February},
   title = {Computations of two-phase fluid flows with phase-field models},
   year = {2016}
}
