@article{Nguyen2004,
   abstract = {The differential adhesion between cells is believed to be the major driving force behind the formation of tissues. The idea is that an aggregate of cells minimizes the overall adhesive energy between cell surfaces. We demonstrate in a model experimental system that there exist conditions where a slowly growing tissue does not minimize this adhesive energy. A mathematical model demonstrates that the instability of a spherical shape is caused by the competition between elastic and surface energies.},
