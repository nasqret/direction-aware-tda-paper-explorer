@article{Cox2003a,
   abstract = {Foam bubbles of constant mean curvature with a number of faces between 3 and 32 have been computer generated. The surface area per unit volume is only weakly dependent upon the number of faces, which allows an approximate equation for the energy of a three-dimensional foam to be derived. A further relation between the rate of change in the volume of a bubble due to gas diffusion and its number of faces is compared with existing theory.},
