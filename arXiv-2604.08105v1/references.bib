@article{Fakult2007,
   abstract = {In early zebrafish embryonic development, complex flows of cell populations occur, which ultimately lead to the spatial organization of the three germ layers: Ectoderm, mesoderm and endoderm. Here, we study the material properties of these germ layer tissues which are },
   author = {Der Fakult},
