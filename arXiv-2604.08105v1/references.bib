   pages = {3017-3020},
   title = {Anomalous viscous loss in emulsions},
   volume = {76},
   year = {1996}
}
@article{Li2016,
   abstract = {Air-exposed droplet systems are widely applied in material preparation and experimental design. Recently, a droplet system with unusual properties featured by a liquid-like appearance and solid-like deformability was produced. However, it was then just an interesting and perplexing phenomenon in the absence of basic understandings and clear perspectives for applications. Here we reveal that stable droplet deformation is attributed to monolayer nanoparticle jamming at the water/vapor interface, and that the normal shape can be recovered by jamming relieving. The degree of jamming affects the droplet shape and transparency and can be tuned by the squeezing force and droplet volume. Using these properties and control methods, we develop the deformed droplet into "liquid plasticine" with predesigned shapes, super-high transparency, and arbitrarily large volume. We demonstrate that liquid plasticine could be used as liquid lenses, channel-like containers, and miniature reactors.},
   author = {Xiaoguang Li and Yahui Xue and Pengyu Lv and Hao Lin and Feng Du and Yueyun Hu and Jun Shen and Huiling Duan},
   doi = {10.1039/c5sm02765a},
   issn = {17446848},
   issue = {6},
   journal = {Soft Matter},
   pages = {1655-1662},
   publisher = {Royal Society of Chemistry},
   title = {Liquid plasticine: Controlled deformation and recovery of droplets with interfacial nanoparticle jamming},
   volume = {12},
   url = {http://dx.doi.org/10.1039/c5sm02765a},
   year = {2016}
}
@article{Krieg2008,
   abstract = {Understanding the factors that direct tissue organization during development is one of the most fundamental goals in developmental biology. Various hypotheses explain cell sorting and tissue organization on the basis of the adhesive and mechanical properties of the constituent cells. However, validating these hypotheses has been difficult due to the lack of appropriate tools to measure these parameters. Here we use atomic force microscopy (AFM) to quantify the adhesive and mechanical properties of individual ectoderm, mesoderm and endoderm progenitor cells from gastrulating zebrafish embryos. Combining these data with tissue self-assembly in vitro and the sorting behaviour of progenitors in vivo, we have shown that differential actomyosin-dependent cell-cortex tension, regulated by Nodal/ TGFβ-signalling (transforming growth factor β), constitutes a key factor that directs progenitor-cell sorting. These results demonstrate a previously unrecognized role for Nodal-controlled cell-cortex tension in germ-layer organization during gastrulation.},
   author = {M. Krieg and Y. Arboleda-Estudillo and P. H. Puech and J. Käfer and F. Graner and D. J. Müller and C. P. Heisenberg},
   doi = {10.1038/ncb1705},
   issn = {14657392},
   issue = {4},
   journal = {Nature Cell Biology},
   pages = {429-436},
   pmid = {18364700},
   title = {Tensile forces govern germ-layer organization in zebrafish},
   volume = {10},
   year = {2008}
}
