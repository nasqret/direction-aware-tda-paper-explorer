   issue = {44},
   journal = {Soft Matter},
   pages = {10599},
   pmid = {24173598},
   title = {Viscous fingering at ultralow interfacial tension},
   volume = {9},
   url = {http://xlink.rsc.org/?DOI=c3sm51571k},
   year = {2013}
}
