   keywords = {3D printing,additive manufacturing,bone tissue engineering,environment-responsive,orthopedic implants,surface modification},
   pages = {1548675},
   pmid = {40078794},
   publisher = {Frontiers Media SA},
   title = {The rational design, biofunctionalization and biological properties of orthopedic porous titanium implants: a review},
   volume = {13},
   url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC11897010/},
   year = {2025}
}
