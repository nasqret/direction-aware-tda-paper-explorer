   journal = {Microfluidics and Nanofluidics},
   keywords = {Double emulsions,Hydrophilic,Microrofluidic,Tin},
   pages = {767-774},
   title = {Hydrophilic polycarbonate chips for generation of oil-in-water (O/W) and water-in-oil-in-water (W/O/W) emulsions},
   volume = {14},
