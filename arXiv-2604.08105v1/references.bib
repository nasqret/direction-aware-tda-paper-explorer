@article{Sollich1997,
   abstract = {We attribute similarities in the rheology of many soft materials (foams, emulsions, slurries, etc.) to the shared features of structural disorder and metastability. A generic model for the mesoscopic dynamics of “soft glassy matter” is introduced, with interactions represented by a mean-field noise temperature x. We find power-law fluid behavior either with (x < 1) or without (1 < x < 2) a yield stress. For 1 < x < 2, both storage and loss modulus vary with frequency as ωz-1, becoming flat near a glass transition (x = 1). Values of x≈1 may result from marginal dynamics as seen in some spin glass models. © 1997 The American Physical Society.},
   author = {Peter Sollich and François Lequeux and Pascal Hébraud and Michael E Cates},
   doi = {10.1103/PhysRevLett.78.2020},
   issn = {10797114},
   issue = {10},
