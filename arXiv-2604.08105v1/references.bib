   title = {Stability of a jet in confined pressure-driven biphasic flows at low reynolds numbers},
   volume = {99},
   year = {2007}
}
@article{Jankowski2013,
   abstract = {Modification of the surfaces of polycarbonate (PC) with the use of a solution of tin (II) chloride renders them hydrophilic. The surface draping is stable against exposure to water and to alcohols. Exposure to alkanes reduces but does not diminish the effect. The method is compatible - in using the same solvent and temperature - with the hydrophobic modification of PC Jankowski et al. (Lab Chip 11:748-752, 2011). The combination of these methods makes it possible to generate single and multiple monodisperse emulsions with the use of flow-focusing junctions in systems made in PC - material that is suitable for fabrication of multilayer, high throughput microfluidic devices. © 2012 The Author(s).},
   author = {Paweł Jankowski and Dominika Ogończyk and Ladislav Derzsi and Wojciech Lisowski and Piotr Garstecki},
