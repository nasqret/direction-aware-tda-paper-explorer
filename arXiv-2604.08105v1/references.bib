}
@article{Masuzzo2015,
   abstract = {Cell migration research has recently become both a high content and a high throughput field thanks to technological, computational, and methodological advances. Simultaneously, however, urgent bioinformatics needs regarding data management, standardization, and dissemination have emerged. To address these concerns, we propose to establish an open data ecosystem for cell migration research.},
   author = {Paola Masuzzo and Lennart Martens and Christophe Ampe and Kurt I. Anderson and Joseph Barry and Olivier De Wever and Olivier Debeir and Christine Decaes-Tecker and Helmut Dolznig and Peter Friedl and Cedric Gaggioli and Benjamin Geiger and Ilya G. Goldberg and Elias Horn and Rick Horwitz and Zvi Kam and Sylvia E. Le Dévédec and Danijela Matic Vignjevic and Josh Moore and Jean Christophe Olivo-Marin and Erik Sahai and Susanna A. Sansone and Victoria Sanz-Moreno and Staffan Strömblad and Jason Swedlow and Johannes Textor and Marleen Van Troys and Roman Zantl},
