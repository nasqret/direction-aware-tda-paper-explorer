   issue = {2},
   journal = {Methods},
   keywords = {Glioma,Invasion,Migration,Rac,siRNA},
   pages = {208-215},
   pmid = {16288884},
   title = {Cell migration and invasion assays},
   volume = {37},
   year = {2005}
}
