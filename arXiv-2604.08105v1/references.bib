   author = {Ole Didrik Laerum and Svein J T Nygaard and Solrun Steine and Olav Engebraaten and Aurelia Peraud and Paul Kleihues and Hiroko Ohgaki},
   keywords = {glioblastoma,invasion,organ culture},
